# Leave empty on Vercel (API runs on the same domain at /api/contact)
# For local dev, leave empty too — Vite proxies /api to localhost:5000
VITE_API_URL=

# Required on Vercel — Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require
